# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=

# Papermark
PAPERMARK_WEBHOOK_SECRET=
PAPERMARK_API_URL=

# Umami
UMAMI_WEBSITE_ID=
UMAMI_API_URL=
UMAMI_API_KEY=

# n8n
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=

# changedetection.io
CHANGEDETECTION_WEBHOOK_SECRET=

# Cal.com (Sprint 10 — webhook only, no SDK)
CALCOM_WEBHOOK_SECRET=

# Content Intelligence v1 (Gemini multimodal analysis — manual batch only)
# CONTENT_ANALYSIS_ENABLED must be the literal string "true" for the script
# to actually call Gemini. Anything else (including unset) short-circuits.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CONTENT_ANALYSIS_ENABLED=false
CONTENT_ANALYSIS_BATCH_LIMIT=5
# Batch limit for the n8n-triggered cron route POST /api/content/analyze-new-cron.
# Default 5, hard-capped to 10 inside the route. Independent from the UI limit
# above so the hourly cron and the operator button can be tuned separately.
CONTENT_ANALYSIS_CRON_BATCH_LIMIT=5

# Provider fallback chain for meme analysis (analyze-new + analyze-new-cron):
#   1. Gemini (primary, always)
#   2. OpenAI  — automatically engaged when OPENAI_API_KEY is set
#   3. Mistral — automatically engaged when MISTRAL_API_KEY is set
# Each hop is skipped silently when its key is absent. A provider failure
# triggers the next hop on HTTP error, rate-limit/quota, timeout, empty
# content, invalid JSON, or schema validation. media_fetch_* and
# media_too_large_* never fall through (next provider hits the same URL).
OPENAI_API_KEY=
OPENAI_CONTENT_ANALYSIS_MODEL=gpt-4o-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-2506
# CLI-only opt-in flag (kept for backward compat with `pnpm content:analyze`):
# leave unset so backfill runs stay Gemini-only by default. The UI/cron
# routes ignore this flag and engage OpenAI whenever OPENAI_API_KEY is set.
CONTENT_ANALYSIS_OPENAI_FALLBACK_ENABLED=false

# App
NEXT_PUBLIC_APP_URL=
NODE_ENV=development
